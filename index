    <script>
        // Keeps track of which dropdown is currently open (-1 means none are open)
        let openIndex = -1;

        // Function called when a menu option is clicked
        function toggle(index) {
            // Grabs all elements on the page with the class 'dropdown'
            const all = document.querySelectorAll('.dropdown');

            // If the user clicks the option that is ALREADY open...
            if (openIndex === index) {
                all[index].classList.remove('open'); // Close it
                openIndex = -1; // Reset tracker to none
            } 
            // If the user clicks a DIFFERENT option...
            else {
                all.forEach(d => d.classList.remove('open')); // Close all dropdowns first
                all[index].classList.add('open'); // Open the newly clicked one
                openIndex = index; // Update tracker to the new one
            }
        }
    </script>
