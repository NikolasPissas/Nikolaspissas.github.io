        /* --- DROPDOWN STYLES --- */
        .dropdown {
            max-height: 0; 
            overflow: hidden; 
            transition: max-height 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease, padding 0.5s cubic-bezier(0.22, 1, 0.36, 1);
            opacity: 0; 
